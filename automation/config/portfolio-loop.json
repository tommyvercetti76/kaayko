          "label": "Kamera predeploy check",
          "repo": "kaayko-api",
          "cwd": "functions",
          "command": "npm run predeploy:check"
        }
      ],
      "risk_checks": [
        "Catalog changes preserve provenance and verification quality.",
        "Recommendation logic changes are backed by explicit evidence notes.",
        "Representative presets were checked before training approval."
      ]
    },
    "shared": {
      "description": "Cross-product frontend quality, shared utilities, and portfolio debt reduction.",
      "learnings_slug": "shared",
      "repos": [
        "kaayko",
        "kaayko-api"
      ],
      "quality_gates": [
        {
          "id": "frontend-static-assets",
